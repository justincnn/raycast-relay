# 运行镜像（可选）
DOCKER_IMAGE=justincnn/raycast-relay:latest

# 本机映射端口（可选）
HOST_PORT=3000

# 访问 /v1/chat/completions 时的鉴权密钥（强烈建议设置）
API_KEY=change_me_to_a_long_random_string

# 从 Raycast 客户端请求中提取，用于访问 Advanced AI 模型（建议设置）
RAYCAST_TOKEN=

# 用于图像上传链路（可选，支持图像输入时建议设置）
IMAGE_TOKEN=

# 可选：自定义 Raycast 签名密钥（通常保持默认空值）
SIG_SECRET=

# 可选：固定 64 位十六进制设备 ID，不填则服务自动生成
DEVICE_ID=

# 可选：是否开启调试日志（true/false 或 1/0）
DEBUG=false
